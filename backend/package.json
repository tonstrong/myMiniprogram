{
  "name": "closet-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:migrate:status": "tsx scripts/migrate-status.ts",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "tsx": "^4.15.4",
    "typescript": "^5.5.4",
    "typescript-language-server": "^5.1.3"
  }
}
