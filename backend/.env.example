APP_ENV=development
APP_PORT=4000
LOG_LEVEL=info

DATABASE_URL=postgres://user:password@localhost:5432/closet
QUEUE_URL=redis://localhost:6379/0
STORAGE_PROVIDER=local
STORAGE_BUCKET=closet-assets

# Provider-agnostic LLM gateway configuration
LLM_PROVIDERS=provider_a,provider_b
LLM_PROVIDER_PRIORITY=provider_a,provider_b
LLM_PROVIDER_TIMEOUT_MS=20000
LLM_PROVIDER_RETRY_LIMIT=2

LLM_PROVIDER_A_BASE_URL=https://api.provider-a.example
LLM_PROVIDER_A_API_KEY=replace_me
LLM_PROVIDER_A_MODEL=multimodal-1

LLM_PROVIDER_B_BASE_URL=https://api.provider-b.example
LLM_PROVIDER_B_API_KEY=replace_me
LLM_PROVIDER_B_MODEL=multimodal-2
