/** 
 * 全局样式体系与设计Token
 * 设计风格：极简主义、玻璃拟物、流体渐变、现代排版 (Rich Aesthetics)
 */

 :root, page {
  /* 调色板 - 灰度系列 */
  --color-bg-primary: #FAFAFA;
  --color-bg-secondary: #F3F4F6;
  --color-bg-card: rgba(255, 255, 255, 0.85); /* 半透明支持玻璃效果 */
  
  /* 字体颜色 */
  --text-main: #1C1C1E;
  --text-secondary: #8E8E93;
  --text-tertiary: #C7C7CC;
  
  /* 品牌色调 - 优雅/冷暖反差 */
  --brand-primary: #1C1C1E;    /* 磨砂黑，彰显衣衫高级感 */
  --brand-accent: #657489;     /* 灰调莫兰迪蓝，作为点缀 */
  --brand-gradient: linear-gradient(135deg, #2E333A 0%, #17181A 100%);
  --brand-pop: #D4A373;        /* 用于高亮、强调 */
  
  /* 辅助状态色 */
  --status-success: #34C759;
  --status-error: #FF3B30;
  --status-warning: #FF9500;
  
  /* 间距系统 */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
  
  /* 阴影效果 */
  --shadow-sm: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  --shadow-md: 0 16rpx 40rpx rgba(0, 0, 0, 0.08);
  --shadow-glass: inset 0 2rpx 0 rgba(255, 255, 255, 0.5), 0 16rpx 32rpx rgba(0, 0, 0, 0.04);
  
  /* 圆角大小 */
  --radius-sm: 12rpx;
  --radius-md: 24rpx;
  --radius-lg: 40rpx;
  --radius-max: 9999rpx;
  
  /* 字体家族 (现代极简) */
  --font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", "PingFang SC", sans-serif;
  
  background-color: var(--color-bg-primary);
  font-family: var(--font-family);
  color: var(--text-main);
  box-sizing: border-box;
}

view, text, image, form, input, button {
  box-sizing: inherit;
}

/* 玻璃拟物态工具类 (Glassmorphism) */
.glass-panel {
  background: var(--color-bg-card);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-glass);
  border: 1px solid rgba(255, 255, 255, 0.4);
}

/* 容器基础布局 */
.container {
  padding: 0 var(--spacing-lg);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 常规文字层级 */
.text-h1 {
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: -0.5px;
  color: var(--text-main);
}
.text-h2 {
  font-size: 44rpx;
  font-weight: 600;
  line-height: 1.3;
}
.text-body {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-main);
}
.text-caption {
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

/* 通用 Flex 帮助类 */
.flex-row {
  display: flex;
  flex-direction: row;
}
.flex-col {
  display: flex;
  flex-direction: column;
}
.items-center {
  align-items: center;
}
.justify-between {
  justify-content: space-between;
}
.justify-center {
  justify-content: center;
}

/* 核心主按钮样式重置 (去除丑陋默认边框，增强质感) */
.btn-primary {
  background: var(--brand-gradient);
  color: #FFF;
  border-radius: var(--radius-max);
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 16rpx 32rpx rgba(28, 28, 30, 0.2);
  transition: all 0.3s ease;
  border: none;
}

.btn-primary:active {
  transform: scale(0.96);
  opacity: 0.9;
}

/* 次要交互按钮 */
.btn-secondary {
  background: rgba(28, 28, 30, 0.05);
  color: var(--text-main);
  border-radius: var(--radius-max);
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  justify-content: center;
  align-items: center;
  border: none;
}

.btn-secondary:active {
  background: rgba(28, 28, 30, 0.1);
  transform: scale(0.96);
}

/* Tag 风格：圆润、低饱和 */
.tag-chip {
  padding: 8rpx 24rpx;
  border-radius: var(--radius-max);
  background: rgba(28, 28, 30, 0.04);
  color: var(--text-secondary);
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
}
.tag-chip.active {
  background: var(--brand-primary);
  color: #ffffff;
}

/* 动态入场动画 (Smooth Animations) */
.animate-fade-in {
  animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  opacity: 0;
  transform: translateY(20rpx);
}

@keyframes fadeIn {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
