.no-pad {
  padding: 0;
  background-color: var(--color-bg-primary);
  min-height: 100vh;
}

.hero-card {
  margin: var(--spacing-md) var(--spacing-lg) var(--spacing-xl);
  padding: var(--spacing-xl);
  background: var(--brand-gradient);
  border: none;
}

.hero-card .text-h2 {
  color: #FFF;
}

.hero-card .text-secondary {
  color: rgba(255,255,255,0.8);
}

.status-badge {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-max);
}
.status-badge.warning { background: var(--status-warning); color: #FFF; }
.status-badge.success { background: var(--status-success); color: #FFF; }

.rules-board {
  padding: 0 var(--spacing-xl);
}

.rule-group {
  display: flex;
  flex-direction: column;
}

.rg-title {
  color: var(--text-main);
  display: flex;
  align-items: center;
}

.icon-edit {
  color: var(--text-tertiary);
  margin-left: 8rpx;
  font-size: 24rpx;
}

.rg-tags {
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}

.rule-tag {
  padding: 10rpx 28rpx;
  border-radius: var(--radius-sm);
  font-size: 26rpx;
}
.rule-tag.color { background: rgba(101,116,137,0.1); color: var(--brand-accent); }
.rule-tag.fit { background: rgba(28,28,30,0.06); color: var(--text-main); }
.rule-tag.avoid { background: rgba(255,59,48,0.08); color: var(--status-error); text-decoration: line-through; }
.rule-tag.scene { background: rgba(212,163,115,0.15); color: #B37D4E; }

.mt-md { margin-top: var(--spacing-md); }
.mt-sm { margin-top: var(--spacing-sm); }
.mt-xl { margin-top: var(--spacing-xl); }
.mb-lg { margin-bottom: var(--spacing-lg); }

.action-area {
  margin-top: 80rpx;
  padding: 0 var(--spacing-xl) 100rpx;
}

.info-tip {
  background: var(--color-bg-secondary);
  padding: var(--spacing-md);
  border-radius: var(--radius-sm);
}

.tip-icon {
  margin-right: var(--spacing-sm);
}
