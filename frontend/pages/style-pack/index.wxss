.header-area {
  margin-top: var(--spacing-sm);
  margin-bottom: var(--spacing-xl);
}

.subtitle {
  color: var(--text-secondary);
  display: block;
  margin-top: var(--spacing-xs);
}

.section-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: var(--spacing-sm);
  font-weight: 500;
}

.mt-2 { margin-top: var(--spacing-sm); }
.mt-4 { margin-top: var(--spacing-xl); }
.w-full { width: 100%; }

.pack-card {
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  align-items: center;
}

.pack-card:active {
  transform: scale(0.98);
}

.pack-card.pending {
  opacity: 0.7;
}

.pack-info {
  flex: 1;
}

.source-tag {
  margin-left: var(--spacing-md);
  background: var(--color-bg-secondary);
  color: var(--brand-primary);
  font-size: 20rpx;
}

.arrow {
  margin-left: var(--spacing-lg);
  font-family: monospace;
}

.spinner.mini {
  width: 24rpx;
  height: 24rpx;
  border-width: 4rpx;
  margin-bottom: 0;
  margin-left: var(--spacing-sm);
}

.action-fixed {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: var(--spacing-lg) var(--spacing-xl) 60rpx;
  background: linear-gradient(to top, rgba(250,250,250,1) 50%, rgba(250,250,250,0) 100%);
}

.pack-list {
  padding-bottom: 200rpx;
}
