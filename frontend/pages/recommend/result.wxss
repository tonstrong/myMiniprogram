.dark-theme {
  background-color: var(--brand-primary);
  color: #FFF;
  padding: 0;
}

.page-title {
  margin-top: var(--spacing-xl);
  margin-bottom: var(--spacing-lg);
  color: #FFF;
}
.text-center { text-align: center; }

.look-swiper {
  height: 1050rpx;
  width: 100%;
}

.si-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
}

.look-card {
  width: 90%;
  height: 95%;
  background: #2E333A;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: 0 16rpx 40rpx rgba(0,0,0,0.5);
  transition: transform 0.3s ease;
  transform: scale(0.95);
  opacity: 0.6;
}
.look-card.active {
  transform: scale(1);
  opacity: 1;
}

.collage-area {
  height: 55%;
  padding: var(--spacing-sm);
  gap: var(--spacing-sm);
  background: #22262B;
}

.cloth-item {
  position: relative;
  height: 100%;
  border-radius: var(--radius-md);
  overflow: hidden;
}

.c-img {
  width: 100%;
  height: 100%;
}

.c-label {
  position: absolute;
  bottom: 16rpx;
  left: 16rpx;
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(8px);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: 20rpx;
  color: #FFF;
}

.reason-area {
  padding: var(--spacing-lg);
}

.r-text {
  color: #FFF;
  font-size: 32rpx;
  line-height: 1.5;
  font-weight: 500;
}

.alt-tip {
  background: rgba(255,255,255,0.05);
  padding: 16rpx;
  border-radius: var(--radius-sm);
}

.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.ml-sm { margin-left: var(--spacing-sm); }
.mt-auto { margin-top: auto; }

.feedback-bar {
  padding: var(--spacing-lg);
  border-top: 1rpx solid rgba(255,255,255,0.05);
}

.fb-btn {
  padding: 16rpx 32rpx;
  border-radius: var(--radius-max);
  font-size: 28rpx;
}
.btn-dislike {
  background: rgba(255,255,255,0.1);
  color: #FFF;
}

.icon-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-left: var(--spacing-md);
}
.icon-btn:active, .fb-btn:active {
  opacity: 0.7;
}

.swiper-dots {
  gap: 16rpx;
}
.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  transition: all 0.3s;
}
.dot.active {
  width: 32rpx;
  border-radius: 8rpx;
  background: #FFF;
}
