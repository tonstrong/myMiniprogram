<view class="container">
  <view class="tab-header flex-row items-center animate-fade-in">
    <block wx:for="{{tabs}}" wx:key="*this">
      <view class="tab-item {{activeTab === index ? 'active' : ''}}" bindtap="switchTab" data-index="{{index}}">
        {{item}}
      </view>
    </block>
  </view>

  <view class="grid-wrap animate-fade-in" style="animation-delay: 0.1s;">
    <view class="empty-state flex-col items-center justify-center glass-panel capability-panel">
      <text class="text-h1 text-tertiary">📭</text>
      <text class="text-body text-secondary mt-md">暂无可展示的历史记录</text>
      <text class="text-caption capability-copy">{{backendMessage}}</text>
      <view class="status-pill {{backendReady ? 'ready' : 'error'}}">
        {{backendReady ? '后端已连通' : '后端未连通'}}
      </view>
      <button class="btn-primary mt-action" bindtap="goRecommend">去生成新搭配</button>
    </view>
  </view>
</view>
