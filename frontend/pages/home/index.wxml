<view class="container">
  <view class="nav-space"></view>

  <view class="header-section animate-fade-in" style="animation-delay: 0.1s;">
    <view class="greeting flex-col">
      <text class="text-caption greeting-date">{{currentDateText}}</text>
      <text class="text-h1">{{greeting}}，{{userName}}</text>
      <text class="text-body subtitle">开始你的搭配灵感之旅吧</text>
    </view>
    <view class="avatar">
      <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill"></image>
      <view wx:else class="avatar-placeholder">{{userName ? userName.slice(0, 1) : '衣'}}</view>
    </view>
  </view>

  <view class="task-section animate-fade-in" wx:if="{{tasks.length > 0}}" style="animation-delay: 0.2s;">
    <block wx:for="{{tasks}}" wx:key="id">
      <view class="task-card flex-row items-center justify-between glass-panel">
        <view class="flex-row items-center">
          <view class="task-icon {{item.type}}"></view>
          <text class="text-body">{{item.title}}</text>
        </view>
        <button class="btn-action" bindtap="handleTask" data-action="{{item.action}}">去处理</button>
      </view>
    </block>
  </view>

  <view class="recommend-section animate-fade-in" style="animation-delay: 0.3s;" bindtap="goRecommend">
    <view class="section-header flex-row justify-between items-center">
      <text class="text-h2">今日推荐</text>
    </view>
    <view class="recommend-card">
      <image wx:if="{{todayRecommend.image}}" class="rc-bg" src="{{todayRecommend.image}}" mode="aspectFill"></image>
      <view wx:else class="rc-bg rc-placeholder">
        <text class="rc-placeholder-text">{{todayRecommend.scene}}</text>
      </view>
      <view class="rc-overlay flex-col justify-between">
        <view class="rc-tags flex-row">
          <view class="tag-chip blur-tag">{{todayRecommend.scene}}</view>
          <view class="tag-chip blur-tag">{{todayRecommend.weather}}</view>
        </view>
        <view class="rc-bottom">
          <text class="rc-reason text-h2">{{todayRecommend.reason}}</text>
          <view class="rc-action flex-row items-center justify-between">
            <text class="text-caption" style="color:#FFF;">进入推荐页 ></text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="stats-inline animate-fade-in" style="animation-delay: 0.35s;">
    <text class="text-caption text-secondary">衣橱单品 {{closetCount}} 件 · 生效风格包 {{stylePackCount}} 个</text>
  </view>

  <view class="action-grid animate-fade-in" style="animation-delay: 0.4s;">
    <view class="action-item glass-panel" bindtap="goUpload">
      <view class="action-icon">➕</view>
      <text class="text-body">录入单品</text>
      <text class="text-caption">拍照或上传</text>
    </view>
    <view class="action-item glass-panel" bindtap="goStylePack">
      <view class="action-icon">✨</view>
      <text class="text-body">风格灵感</text>
      <text class="text-caption">管理风格包</text>
    </view>
  </view>
</view>
