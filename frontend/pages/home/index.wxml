<view class="container">
  
  <!-- иҮӘе®ҡд№үеҜјиҲӘж Ҹйў„з•ҷз©әй—ҙ -->
  <view class="nav-space"></view>

  <!-- еӨҙйғЁй—®еҖҷеҢәеҹ?-->
  <view class="header-section animate-fade-in" style="animation-delay: 0.1s;">
    <view class="greeting flex-col">
      <text class="text-caption greeting-date">4жң?0ж—?жҳҹжңҹеӣ?/text>
      <text class="text-h1">{{greeting}}, {{userName}}.</text>
      <text class="text-body subtitle">ејҖе§ӢдҪ зҡ„жҗӯй…ҚзҒөж„ҹд№Ӣж—…еҗ§</text>
    </view>
    <view class="avatar">
      <image class="avatar-img" src="https://dummyimage.com/100x100/1C1C1E/FFFFFF?text=User" mode="aspectFill"></image>
    </view>
  </view>

  <!-- еҫ…еҠһд»»еҠЎж°”жіЎ (еҰӮжһңжң? -->
  <view class="task-section animate-fade-in" wx:if="{{tasks.length > 0}}" style="animation-delay: 0.2s;">
    <block wx:for="{{tasks}}" wx:key="id">
      <view class="task-card flex-row items-center justify-between glass-panel">
        <view class="flex-row items-center">
          <view class="task-icon {{item.type}}"></view>
          <text class="text-body">{{item.title}}</text>
        </view>
        <button class="btn-action">еҺ»еӨ„зҗ?/button>
      </view>
    </block>
  </view>

  <!-- д»Ҡж—ҘжҺЁиҚҗеӨ§еҚЎзү?-->
  <view class="recommend-section animate-fade-in" style="animation-delay: 0.3s;" bindtap="goRecommend">
    <view class="section-header flex-row justify-between items-center">
      <text class="text-h2">д»Ҡж—ҘжҺЁиҚҗ</text>
    </view>
    <view class="recommend-card">
      <image class="rc-bg" src="{{todayRecommend.image}}" mode="aspectFill"></image>
      <view class="rc-overlay flex-col justify-between">
        <view class="rc-tags flex-row">
          <view class="tag-chip blur-tag">{{todayRecommend.scene}}</view>
          <view class="tag-chip blur-tag">{{todayRecommend.weather}}</view>
        </view>
        <view class="rc-bottom">
          <text class="rc-reason text-h2">вҖң{{todayRecommend.reason}}вҖ?/text>
          <view class="rc-action flex-row items-center justify-between">
            <text class="text-caption" style="color:#FFF;">жҹҘзңӢжӣҙеӨҡжҗӯй…Қжҗӯй…Қ ></text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- еҝ«жҚ·ж“ҚдҪңе…ҘеҸЈ -->
  <view class="action-grid animate-fade-in" style="animation-delay: 0.4s;">
    <view class="action-item glass-panel" bindtap="goUpload">
      <view class="action-icon">вһ?/view>
      <text class="text-body">еҪ•е…ҘеҚ•е“Ғ</text>
      <text class="text-caption">жӢҚз…§жҲ–дёҠдј?/text>
    </view>
    <view class="action-item glass-panel" bindtap="goStylePack">
      <view class="action-icon">вң?/view>
      <text class="text-body">йЈҺж јзҒөж„ҹ</text>
      <text class="text-caption">з®ЎзҗҶйЈҺж јеҢ?/text>
    </view>
  </view>

</view>
