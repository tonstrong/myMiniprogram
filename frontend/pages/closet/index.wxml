<view class="container">
  
  <!-- 头部统计与筛选 -->
  <view class="closet-header animate-fade-in">
    <text class="text-h1">数字化单品</text>
    <text class="text-body subtitle">看看今天衣橱里有什么灵感</text>
    
    <scroll-view class="filter-scroll" scroll-x="true" show-scrollbar="false">
      <view class="filter-list flex-row">
        <block wx:for="{{filters}}" wx:key="*this">
          <view class="filter-item {{activeFilter === index ? 'active' : ''}}" 
                bindtap="switchFilter" data-index="{{index}}">
            <text>{{item.label}}</text>
          </view>
        </block>
      </view>
    </scroll-view>
  </view>

  <!-- 瀑布流容器 (简化实现为 flex wrap) -->
  <view class="waterfall animate-fade-in" style="animation-delay: 0.1s;">
    <view class="col-left">
      <block wx:for="{{items}}" wx:key="id" wx:if="{{index % 2 === 0}}">
        <view class="item-card glass-panel" bindtap="goDetail" data-id="{{item.id}}">
          <image wx:if="{{item.img}}" class="i-img" src="{{item.img}}" mode="widthFix"></image>
          <view wx:else class="i-placeholder">
            <text class="i-placeholder-text">单品</text>
          </view>
          <view class="i-info">
            <text class="text-body font-medium">{{item.title}}</text>
            <view class="i-tags flex-row">
              <block wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">
                <view class="mini-tag">{{tag}}</view>
              </block>
            </view>
          </view>
        </view>
      </block>
    </view>
    <view class="col-right">
      <block wx:for="{{items}}" wx:key="id" wx:if="{{index % 2 !== 0}}">
        <view class="item-card glass-panel" bindtap="goDetail" data-id="{{item.id}}">
          <image wx:if="{{item.img}}" class="i-img" src="{{item.img}}" mode="widthFix"></image>
          <view wx:else class="i-placeholder">
            <text class="i-placeholder-text">单品</text>
          </view>
          <view class="i-info">
            <text class="text-body font-medium">{{item.title}}</text>
            <view class="i-tags flex-row">
              <block wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">
                <view class="mini-tag">{{tag}}</view>
              </block>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 悬浮长驻添加按钮 -->
  <view class="fab-btn" bindtap="goUpload">
    <view class="fab-icon">
      <view class="fab-line fab-line-horizontal"></view>
      <view class="fab-line fab-line-vertical"></view>
    </view>
  </view>
</view>
